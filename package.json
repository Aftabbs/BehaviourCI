{
  "name": "behaviourci",
  "version": "1.0.0",
  "description": "Behavioral testing for AI features — catch regressions in CI/CD before they reach users",
  "type": "module",
  "main": "dist/action/index.js",
  "bin": {
    "behaviourci": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "examples/",
    "supabase/migrations/",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:action": "ncc build src/action/index.ts -o action-dist --source-map --license licenses.txt",
    "build:all": "npm run build && npm run build:action",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run build",
    "dev": "tsx watch src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "cli": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.36.3",
    "@supabase/supabase-js": "^2.47.10",
    "axios": "^1.7.9",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "groq-sdk": "^0.8.0",
    "js-yaml": "^4.1.0",
    "jsonpath-plus": "^10.2.0",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "testing",
    "behavioral-testing",
    "ci-cd",
    "llm",
    "regression-testing",
    "github-actions",
    "ai-testing",
    "prompt-testing",
    "llm-evaluation",
    "ai-quality",
    "ai-observability",
    "ml-testing",
    "ai-regression"
  ],
  "homepage": "https://github.com/Aftabbs/BehaviourCI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aftabbs/BehaviourCI.git"
  },
  "bugs": {
    "url": "https://github.com/Aftabbs/BehaviourCI/issues"
  },
  "author": "Aftab",
  "license": "MIT"
}
