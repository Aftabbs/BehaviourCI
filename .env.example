# BehaviorCI — Environment Variables
# Copy this file to .env and fill in your values

# ── LLM Providers (at least one required) ──────────────────────────────────
# Groq is recommended — free tier at https://console.groq.com
GROQ_API_KEY=

# Optional secondary providers (for testing your AI feature against different models)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Azure OpenAI (alternative to standard OpenAI)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Supabase (optional — enables dashboard and result history) ─────────────
# Create a free project at https://supabase.com
# Then run supabase/migrations/001_init.sql in the SQL editor
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
